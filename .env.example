# =============================================================================
# TRIMARK — Variáveis de ambiente (PRD §15)
# Copie para .env.local (frontend) e configure como secrets no Supabase.
# Edge Functions leem de Deno.env; o frontend Vite só vê variáveis com prefixo VITE_.
# =============================================================================

# ----- Supabase (frontend Vite) -----
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# ----- Supabase (Edge Functions / scripts CLI) -----
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # ADMIN — nunca expor ao frontend

# ----- Z-API (WhatsApp) (PRD §11.1) -----
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=
ZAPI_WEBHOOK_TOKEN=                       # Validação do webhook /whatsapp-receive

# ----- Asaas (Pagamentos) (PRD §11.2) -----
ASAAS_API_KEY=
ASAAS_ENV=sandbox                         # sandbox | production
ASAAS_WEBHOOK_TOKEN=                      # Header asaas-access-token

# ----- Anthropic Claude (PRD §11.3) -----
ANTHROPIC_API_KEY=sk-ant-...

# ----- E-mail transacional -----
RESEND_API_KEY=

# ----- Criptografia -----
ENCRYPTION_KEY=                           # 32 chars p/ pgcrypto (CPF/CNPJ — PRD §18.3)

# ----- URLs públicas -----
APP_BASE_URL=https://app.trimark.com.br
PORTAL_BASE_URL=https://portal.trimark.com.br
